{
  "name": "datasynx-opencrm",
  "version": "0.1.0",
  "description": "Local-first, MCP-native CRM. One agent per customer. npm install.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./mcp": {
      "import": {
        "types": "./dist/mcp.d.ts",
        "default": "./dist/mcp.js"
      },
      "require": {
        "types": "./dist/mcp.d.cts",
        "default": "./dist/mcp.cjs"
      }
    }
  },
  "bin": {
    "dxcrm": "./dist/cli.js",
    "datasynx-opencrm": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown && node scripts/postbuild.js",
    "dev": "tsx watch src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@huggingface/transformers": "^3.8.1",
    "@iarna/toml": "^2.2.5",
    "@lancedb/lancedb": "^0.29.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@topcli/spinner": "^2.0.0",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "ansis": "^3.0.0",
    "apache-arrow": "^17.0.0",
    "chokidar": "^4.0.0",
    "cli-table3": "^0.6.3",
    "commander": "^14.0.0",
    "cron": "^4.4.0",
    "googleapis": "^140.0.0",
    "gray-matter": "^4.0.3",
    "slug": "^9.0.0",
    "which": "^4.0.0",
    "zod": "^3.25.0",
    "zod-validation-error": "^3.0.0"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/iarna__toml": "^2.0.0",
    "@types/slug": "^5.0.0",
    "@types/which": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "memfs": "^4.0.0",
    "tsdown": "^0.12.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
